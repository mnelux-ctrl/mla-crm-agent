# ── API Security ─────────────────────────────────────────
CRM_API_KEY=mla-crm-2026-secure-key-xyz
CRM_INTERNAL_KEY=mla-crm-internal-2026-secure-xyz

# ── Airtable ─────────────────────────────────────────────
AIRTABLE_PAT=pat...
AIRTABLE_BASE_ID=appMa1XAD2JXQgrfV

# ── Redis (Railway shared) ───────────────────────────────
REDIS_URL=redis://default:...@redis.railway.internal:6379

# ── Downstream: email-agent ──────────────────────────────
EMAIL_AGENT_URL=https://mla-email-agent-production.up.railway.app
EMAIL_AGENT_INTERNAL_KEY=shared-secret-that-email-agent-also-knows

# ── Downstream: SuperKnowledge (optional) ────────────────
SUPERKNOWLEDGE_URL=https://mla-superknowledge-production.up.railway.app
SUPERKNOWLEDGE_API_KEY=mla-sk-2026-secure-key-xyz

# ── AI (optional, for instructions_override pass) ────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4

# ── Slack ────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_STEFAN_USER_ID=U...
SLACK_DEFAULT_CHANNEL=D...

# ── Send safety ──────────────────────────────────────────
GMAIL_DAILY_LIMIT=1500
MIN_GAP_SECONDS=90

# ── Multi-tenancy (leave default for MLA) ────────────────
DEFAULT_ORG_ID=mla

# ── Infra ────────────────────────────────────────────────
PORT=8005
ENV=production
TIMEZONE=Europe/Podgorica

# ── Sender identity (for template placeholder fallback) ──
DEFAULT_SENDER_NAME=Stefan Stešević
DEFAULT_SENDER_TITLE=Founder & Executive Director
DEFAULT_EVENT_NAME=LTSM 2026
